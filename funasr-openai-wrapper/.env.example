FUNASR_HOST=localhost
FUNASR_PORT=10095
FUNASR_SSL=1
FUNASR_PATH=/asr
FUNASR_HOST_HEADER=
FUNASR_MODE=2pass
FUNASR_CHUNK_SIZE=5,10,5
FUNASR_CHUNK_INTERVAL=10
FUNASR_AUDIO_FS=16000
FUNASR_USE_ITN=1
FUNASR_SEND_WITHOUT_SLEEP=1
FUNASR_RECEIVE_TIMEOUT_SECONDS=30

# Optional. If set, requests must include Authorization: Bearer <value>.
WRAPPER_API_KEY=
